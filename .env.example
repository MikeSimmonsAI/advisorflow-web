# .env.example
# Copy this to .env for local development (never commit the real .env file).
# For production, set these in your Render/Railway dashboard instead.

# --- Database ---
# Local dev: sqlite is fine. Production: use the Postgres URL Render gives you.
DATABASE_URL=sqlite:///./advisorflow.db

# --- Security (generate these, don't reuse the examples below) ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-real-random-secret

# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-a-real-fernet-key

# --- Booking backend (already deployed, this URL is correct as-is) ---
BOOKING_BASE_URL=https://advisorflow-booking.vercel.app

# --- Frontend URL (for OAuth redirects to land in the right place) ---
FRONTEND_URL=http://localhost:5173

# --- OpenAI (for AI lead quality analysis) ---
# This is the same key that's been hitting 429 rate limits - add billing
# at platform.openai.com before relying on this in production. The
# fallback heuristic in ai_analysis_service.py covers you in the meantime.
OPENAI_API_KEY=

# --- SendGrid (for email-only outreach and HOT reply notifications) ---
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=noreply@restland-advisorflow.com

# --- Google Calendar OAuth ---
# Set these up in Google Cloud Console: create an OAuth 2.0 Client ID,
# enable the Calendar API, and set the redirect URI to match
# GOOGLE_REDIRECT_URI below exactly (must match what's registered in
# Google Cloud Console or the OAuth flow will fail).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/oauth/callback

# --- Twilio ---
# NOTE: Twilio credentials are NOT set here as environment variables -
# each advisor enters their own Twilio Account SID, Auth Token, and
# phone number through the Settings page in the app itself. This is
# intentional: it's what makes the system multi-tenant (5 advisors,
# 5 separate Twilio accounts, billed separately). There is no global
# Twilio env var to set.
